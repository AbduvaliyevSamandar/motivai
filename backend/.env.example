# MotivAI Backend - Environment Variables
APP_NAME=MotivAI
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-minimum-32-chars-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/motivai?retryWrites=true&w=majority
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
ALLOWED_ORIGINS=*
HOST=0.0.0.0
PORT=8000
